{
  "name": "thistlecc",
  "version": "2.0.0",
  "description": "Bun-native TypeScript compiler driver for mikuOS Thistle64 RV64GC THX executables",
  "type": "module",
  "bin": {
    "thistlecc": "./bin/thistlecc.ts",
    "thistle++": "./bin/thistlecc.ts"
  },
  "files": [
    "bin",
    "src",
    "README.md",
    "LICENSE",
    "thistlecc.schema.json",
    "CHANGELOG.md",
    "MIGRATION.md",
    "install-into-project.sh"
  ],
  "scripts": {
    "check": "tsc -p tsconfig.json --noEmit",
    "test": "bun run ./test/test.ts && bun run ./test/thistleasm-compat.ts",
    "test:node": "rm -rf dist && tsc -p tsconfig.build.json && node ./dist/test/test.js"
  },
  "engines": {
    "bun": ">=1.2.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.8.0"
  },
  "keywords": [
    "mikuos",
    "thistle",
    "teto",
    "riscv64",
    "rv64gc",
    "musl",
    "thx"
  ],
  "license": "MIT"
}
